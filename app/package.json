{
  "name": "@koala-habit/app",
  "version": "1.21",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client --host lan --port 8082",
    "ios": "expo start --ios --dev-client --host lan --port 8082",
    "android": "expo start --android --dev-client --host lan --port 8082",
    "build:preview": "npx eas-cli@latest build --profile preview --platform all",
    "build:preview:android": "npx eas-cli@latest build --profile preview --platform android",
    "build:preview:ios": "npx eas-cli@latest build --profile preview --platform ios",
    "build:preview:simulator": "npx eas-cli@latest build --profile preview-simulator --platform ios",
    "device": "../../scripts/start-device.sh",
    "ipad": "../../scripts/start-ipad.sh",
    "web": "expo start --web --port 8082",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.24",
    "expo-audio": "~55.0.14",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-image-picker": "~55.0.20",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-speech": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  }
}
