{
  "expo": {
    "name": "Koala Habit",
    "slug": "koala-habit",
    "version": "0.1.0",
    "orientation": "landscape",
    "scheme": "koalahabit",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koalahabit.app"
    },
    "android": {
      "package": "com.koalahabit.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
